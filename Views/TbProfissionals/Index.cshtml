@model IEnumerable<Projeto1_Web2_IF_johnnata.Models.TbProfissional>

@{
    var isManager = ViewData["IsManager"] as bool? ?? false;
    var managerType = ViewData["ManagerType"] as string ?? "";
    
    if (isManager)
    {
        ViewData["Title"] = "Gerenciar Profissionais";
    }
    else
    {
        ViewData["Title"] = "Meus Dados";
    }
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (isManager)
{
    <h1>
        <i class="fas fa-users-cog"></i> Gerenciar Profissionais
    </h1>
    <p class="lead">
        @if (managerType == "GerenteMedico")
        {
            <span class="badge badge-primary">Gerente Médico</span>
            <span class="text-muted">Visualizando apenas profissionais Médicos</span>
        }
        else if (managerType == "GerenteNutricionista")
        {
            <span class="badge badge-success">Gerente Nutricionista</span>
            <span class="text-muted">Visualizando apenas profissionais Nutricionistas</span>
        }
        else if (managerType == "GerenteGeral")
        {
            <span class="badge badge-warning">Gerente Geral</span>
            <span class="text-muted">Visualizando todos os profissionais</span>
        }
    </p>
}
else
{
    <h1>
        <i class="fas fa-user"></i> Meus Dados de Profissional
    </h1>
}

<hr />

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Tipo</th>
                <th>Nome</th>
                <th>CPF</th>
                <th>CRM/CRN</th>
                <th>Especialidade</th>
                <th>Cidade</th>
                <th>Telefone</th>
                <th>Plano</th>
                @if (isManager)
                {
                    <th>Salário</th>
                }
                <th style="min-width: 150px;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (item.IdTipoProfissional == 1)
                            {
                                <span class="badge badge-primary">Médico</span>
                            }
                            else if (item.IdTipoProfissional == 2)
                            {
                                <span class="badge badge-success">Nutricionista</span>
                            }
                            else
                            {
                                <span>@item.IdTipoProfissional</span>
                            }
                        </td>
                        <td>
                            <strong>@item.Nome</strong>
                        </td>
                        <td>@item.Cpf</td>
                        <td>@item.CrmCrn</td>
                        <td>@item.Especialidade</td>
                        <td>
                            @if (item.IdCidadeNavigation != null)
                            {
                                <text>@item.IdCidadeNavigation.Nome</text>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Telefone1))
                            {
                                <text>(@item.Ddd1) @item.Telefone1</text>
                            }
                        </td>
                        <td>
                            @if (item.IdContratoNavigation?.IdPlanoNavigation != null)
                            {
                                <strong>@item.IdContratoNavigation.IdPlanoNavigation.Nome</strong>
                                <br />
                                <small class="text-muted">Contrato #@item.IdContratoNavigation.IdContrato</small>
                            }
                        </td>
                        @if (isManager)
                        {
                            <td>
                                @if (item.Salario.HasValue)
                                {
                                    <text>R$ @item.Salario.Value.ToString("N2")</text>
                                }
                                else
                                {
                                    <text>-</text>
                                }
                            </td>
                        }
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@item.IdProfissional" 
                                   class="btn btn-sm btn-info" title="Visualizar">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.IdProfissional" 
                                   class="btn btn-sm btn-primary" title="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (isManager)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.IdProfissional" 
                                       class="btn btn-sm btn-danger" title="Excluir">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="@(isManager ? "10" : "9")" class="text-center text-muted">
                        <i class="fas fa-info-circle"></i> Nenhum profissional encontrado.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}