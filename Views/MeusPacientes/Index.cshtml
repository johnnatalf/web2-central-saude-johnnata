@model IEnumerable<Projeto1_Web2_IF_johnnata.Models.TbPaciente>

@{
    ViewData["Title"] = "Meus Pacientes";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-12">
            <h1><i class="fas fa-users"></i> Meus Pacientes</h1>
            <p class="text-muted">Lista de pacientes cadastrados por você</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-12">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Cadastrar Novo Paciente
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>Data Nascimento</th>
                        <th>Sexo</th>
                        <th>Cidade</th>
                        <th>Telefone</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Nome)</td>
                            <td>@Html.DisplayFor(modelItem => item.Cpf)</td>
                            <td>@item.DataNascimento.ToString("dd/MM/yyyy")</td>
                            <td>@(item.Sexo == "M" ? "Masculino" : item.Sexo == "F" ? "Feminino" : item.Sexo)</td>
                            <td>@Html.DisplayFor(modelItem => item.IdCidadeNavigation.Nome)</td>
                            <td>@(item.TelCelular ?? item.TelResidencial ?? item.TelComercial ?? "-")</td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.IdPaciente" class="btn btn-sm btn-info" title="Detalhes">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.IdPaciente" class="btn btn-sm btn-warning" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.IdPaciente" class="btn btn-sm btn-danger" title="Excluir">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> Você ainda não possui pacientes cadastrados.
        </div>
    }
</div>
