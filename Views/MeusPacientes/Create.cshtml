@model Projeto1_Web2_IF_johnnata.Models.TbPaciente

@{
    ViewData["Title"] = "Cadastrar Paciente";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1><i class="fas fa-user-plus"></i> Cadastrar Novo Paciente</h1>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <h4 class="mt-3 mb-3">Dados Pessoais</h4>
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group mb-3">
                            <label asp-for="Nome" class="form-label">Nome Completo *</label>
                            <input asp-for="Nome" class="form-control" required />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="DataNascimento" class="form-label">Data de Nascimento *</label>
                            <input asp-for="DataNascimento" type="date" class="form-control" required />
                            <span asp-validation-for="DataNascimento" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Cpf" class="form-label">CPF *</label>
                            <input asp-for="Cpf" id="Cpf" class="form-control" placeholder="000.000.000-00" required />
                            <span asp-validation-for="Cpf" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Rg" class="form-label">RG *</label>
                            <input asp-for="Rg" id="Rg" class="form-control" placeholder="00.000.000-0" required />
                            <span asp-validation-for="Rg" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Sexo" class="form-label">Sexo *</label>
                            <select asp-for="Sexo" class="form-select" required>
                                <option value="">Selecione...</option>
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                            </select>
                            <span asp-validation-for="Sexo" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Etnia" class="form-label">Etnia *</label>
                            <select asp-for="Etnia" class="form-select" required>
                                <option value="">Selecione...</option>
                                <option value="1">Branco</option>
                                <option value="2">Preto</option>
                                <option value="3">Pardo</option>
                                <option value="4">Amarelo</option>
                                <option value="5">Indígena</option>
                            </select>
                            <span asp-validation-for="Etnia" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Profissao" class="form-label">Profissão</label>
                            <input asp-for="Profissao" class="form-control" />
                            <span asp-validation-for="Profissao" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group mb-3">
                            <label asp-for="NomeResponsavel" class="form-label">Nome do Responsável</label>
                            <input asp-for="NomeResponsavel" class="form-control" />
                            <small class="form-text text-muted">Preencher apenas se o paciente for menor de idade</small>
                            <span asp-validation-for="NomeResponsavel" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label class="form-label">Características</label>
                            <div class="form-check">
                                <input type="checkbox" id="FlgAtleta" name="FlgAtleta" value="true" class="form-check-input" />
                                <input type="hidden" name="FlgAtleta" value="false" />
                                <label for="FlgAtleta" class="form-check-label">É Atleta</label>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" id="FlgGestante" name="FlgGestante" value="true" class="form-check-input" />
                                <input type="hidden" name="FlgGestante" value="false" />
                                <label for="FlgGestante" class="form-check-label">Gestante</label>
                            </div>
                        </div>
                    </div>
                </div>

                <h4 class="mt-4 mb-3">Endereço</h4>
                <div class="row">
                    <div class="col-md-8">
                        <div class="form-group mb-3">
                            <label asp-for="Endereco" class="form-label">Endereço</label>
                            <input asp-for="Endereco" class="form-control" />
                            <span asp-validation-for="Endereco" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="Bairro" class="form-label">Bairro</label>
                            <input asp-for="Bairro" class="form-control" />
                            <span asp-validation-for="Bairro" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label for="IdEstado" class="form-label">Estado</label>
                            <select id="IdEstado" class="form-select" asp-items="ViewBag.IdEstado">
                                <option value="">Selecione o Estado</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="IdCidade" class="form-label">Cidade</label>
                            <select asp-for="IdCidade" class="form-select" asp-items="ViewBag.IdCidade">
                                <option value="">Selecione primeiro o Estado</option>
                            </select>
                            <span asp-validation-for="IdCidade" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <h4 class="mt-4 mb-3">Contatos</h4>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TelResidencial" class="form-label">Telefone Residencial</label>
                            <input asp-for="TelResidencial" id="TelResidencial" class="form-control" placeholder="(00) 0000-0000" />
                            <span asp-validation-for="TelResidencial" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TelComercial" class="form-label">Telefone Comercial</label>
                            <input asp-for="TelComercial" id="TelComercial" class="form-control" placeholder="(00) 0000-0000" />
                            <span asp-validation-for="TelComercial" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group mb-3">
                            <label asp-for="TelCelular" class="form-label">Telefone Celular</label>
                            <input asp-for="TelCelular" id="TelCelular" class="form-control" placeholder="(00) 00000-0000" />
                            <span asp-validation-for="TelCelular" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <h4 class="mt-4 mb-3">Informações Adicionais</h4>
                <div class="form-group mb-3">
                    <label for="InformacaoResumida" class="form-label">Informação Resumida</label>
                    <textarea id="InformacaoResumida" name="InformacaoResumida" class="form-control" rows="4" placeholder="Adicione informações resumidas sobre o paciente (opcional)"></textarea>
                    <small class="form-text text-muted">Estas informações ficarão disponíveis apenas para você</small>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Cadastrar Paciente
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Voltar para Lista
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <script>
        $(document).ready(function () {
            // Máscaras para os campos
        $('#Cpf').mask('000.000.000-00');
            $('#Rg').mask('00.000.000-0');
            $('#TelResidencial').mask('(00) 0000-0000');
            $('#TelComercial').mask('(00) 0000-0000');
            
            // Máscara para celular com 9 dígitos
            var SPMaskBehavior = function (val) {
                return val.replace(/\D/g, '').length === 11 ? '(00) 00000-0000' : '(00) 0000-00009';
            },
            spOptions = {
                onKeyPress: function(val, e, field, options) {
                    field.mask(SPMaskBehavior.apply({}, arguments), options);
                }
            };
            $('#TelCelular').mask(SPMaskBehavior, spOptions);

            // Carregar cidades quando o estado é selecionado
            $('#IdEstado').change(function () {
                var estadoId = $(this).val();
                var cidadeDropdown = $('#IdCidade');

                cidadeDropdown.empty();
                cidadeDropdown.append('<option value="">Carregando...</option>');

                if (estadoId) {
                    $.ajax({
                        url: '@Url.Action("GetCidadesByEstado", "MeusPacientes")',
                        type: 'GET',
                        data: { idEstado: estadoId },
                        success: function (data) {
                            cidadeDropdown.empty();
                            cidadeDropdown.append('<option value="">Selecione a Cidade</option>');
                            $.each(data, function (i, cidade) {
                                cidadeDropdown.append($('<option></option>').val(cidade.value).html(cidade.text));
                            });
                        },
                        error: function () {
                            cidadeDropdown.empty();
                            cidadeDropdown.append('<option value="">Erro ao carregar cidades</option>');
                        }
                    });
                } else {
                    cidadeDropdown.empty();
                    cidadeDropdown.append('<option value="">Selecione primeiro o Estado</option>');
                }
            });
        });
    </script>
}
